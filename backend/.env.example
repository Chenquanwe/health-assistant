# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/health_agent
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/health_agent

# DashScope API（阿里云大模型）
DASHSCOPE_API_KEY=你的DashScope_API密钥

# OpenAI 兼容配置（DashScope 兼容模式）
OPENAI_API_KEY=你的OpenAI_API密钥
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM 模型配置
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v4

# OCR API（可选）
OCR_SPACE_API_KEY=你的OCR.space_API密钥

# CORS 允许的源
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# LangSmith 追踪（可选）
LANGSMITH_API_KEY=你的LangSmith_API密钥
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=智能健康助手
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com